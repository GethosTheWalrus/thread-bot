# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chatbot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Temporal
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=chatbot-task-queue

# LLM API (Ollama default)
LLM_API_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_STREAM_TIMEOUT=120

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# App
APP_NAME=ThreadBot
